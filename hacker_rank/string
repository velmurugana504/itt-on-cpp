#include <iostream>
#include <string>
#include <algorithm>

int main() {
    std::string a, b;
    std::cin >> a >> b;
    std::cout << a.length() << " " << b.length() << std::endl;
    std::string c = a + b;
    std::cout << c << std::endl;
    std::swap(a[0], b[0]);
    std::cout << a << " " << b << std::endl;

    return 0;
}
